DATABASE_URL=postgresql+psycopg2://beeplan:beeplan@localhost:5432/beeplan
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
BUILDER_URL=http://localhost:9000
# Если API в Docker (docker compose): BUILDER_URL=http://builder:9000
BUILDER_SECRET=dev-builder-secret
# URL API с ПК/ESP32 (LAN-IP), для ссылки на прошивку в браузере:
# PUBLIC_API_BASE_URL=http://192.168.1.42:8000
PUBLIC_API_BASE_URL=http://localhost:8000
FIRMWARE_BUILD_TTL_MINUTES=60
# Лимит POST /v1/firmware/builds на пользователя за скользящий час (без учёта status=failed)
FIRMWARE_BUILDS_PER_HOUR=60
